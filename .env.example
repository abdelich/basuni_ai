# Скопируйте в .env и заполните значения.
# Токены создаются в Discord Developer Portal (отдельное приложение на каждого бота).

# БД (по умолчанию — SQLite в data/basuni.db)
# DATABASE_URL=sqlite+aiosqlite:///data/basuni.db

# Токены Discord — по одному на роль (совет = 3 бота)
DISCORD_TOKEN_ELDER=
DISCORD_TOKEN_COUNCIL_1=
DISCORD_TOKEN_COUNCIL_2=
DISCORD_TOKEN_COUNCIL_3=
# DISCORD_TOKEN_PROSECUTOR=
# DISCORD_TOKEN_KPP=
# DISCORD_TOKEN_JUDGE=

# Языковая модель (OpenAI или совместимый API). Для нейтральной модели без встроенной политики — OpenRouter, локальная модель и т.д.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# Рекомендуется gpt-4o для старейшины (сроки, дела суда). Для экономии: gpt-4o-mini (может путать логику).
# Для другого провайдера (OpenRouter, local): укажи base_url и модель, например:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.1-70b-instruct